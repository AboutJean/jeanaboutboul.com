  }

  .p9 {
    padding: 15px;
    background: white;
  }

  .p9-inner {
    border: 4px solid var(--m-black);
    height: 100%;
    display: flex;
    flex-direction: column;
    box-sizing: border-box;
  }

  .p9-top {
    border-bottom: 4px solid var(--m-black);
    padding: 15px 25px;
