    font-size: 10px;
    color: #555;
  }

  .p1 {
    border-top: 5px solid var(--m-red);
    border-right: 5px solid var(--m-blue);
    border-bottom: 5px solid var(--m-yellow);
    border-left: 5px solid var(--m-black);
