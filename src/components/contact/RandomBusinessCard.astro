<script is:inline>
  (() => {
    const root = document.querySelector("[data-random-cards]");
    const host = root?.querySelector("[data-card-host]");
    const shell = root?.querySelector(".card-scale-shell");
    const templates = root ? Array.from(root.querySelectorAll("template[data-card-template]")) : [];

    if (!root || !host || !shell || templates.length === 0) return;

    function applyScale() {
      const availableWidth = root.clientWidth;
      const scale = Math.min(0.88, availableWidth / 600);
      shell.style.setProperty("--card-scale", String(Math.max(scale, 0.52)));
    }

    const randomTemplate = templates[Math.floor(Math.random() * templates.length)];
    host.replaceChildren(randomTemplate.content.cloneNode(true));
    applyScale();
    window.addEventListener("resize", applyScale, { passive: true });
  })();
</script>

<style is:global>
  :root {
    --m-red: #D52B1E;
    --m-blue: #0033A0;
    --m-yellow: #FFC72C;
    --m-black: #1A1A1A;
    --bg-page: #F8F9FA;
    --card-width: 600px;
    --card-height: 350px;
  }

  .cards-randomizer {
    width: min(100%, 36rem);
    margin-inline: auto;
  }

  .card-scale-shell {
    --card-scale: 0.88;
    width: calc(var(--card-width) * var(--card-scale));
    height: calc(var(--card-height) * var(--card-scale));
    margin: 0 auto;
  }

  .card-stage {
    width: var(--card-width);
    height: var(--card-height);
    transform: scale(var(--card-scale));
    transform-origin: top left;
  }

  .card {
    width: var(--card-width);
    height: var(--card-height);
    background-color: #ffffff;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.1);
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
    color: var(--m-black);
    transition: transform 0.3s ease;
  }

  .card:hover {
    transform: translateY(-5px);
  }

  .card a {
    color: inherit;
    text-decoration: none;
  }

  .font-serif {
    font-family: "Playfair Display", serif;
  }

  .font-sans {
    font-family: "Montserrat", sans-serif;
  }

  .spacing-wide {
    letter-spacing: 6px;
  }

  .spacing-medium {
    letter-spacing: 3px;
  }

  .spacing-small {
    letter-spacing: 1px;
  }

  .classic-layout {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    padding: 40px;
    box-sizing: border-box;
  }

  .top-row {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
    align-items: center;
  }

  .icons i {
    font-size: 16px;
    margin-left: 15px;
    color: #333;
  }

  .center-block {
    text-align: center;
  }

  .name {
    font-size: 32px;
    margin-bottom: 15px;
  }

  .title {
    font-size: 11px;
    color: #444;
  }

  .bottom-row {
