    <span style="--span: 1">Toggle<small>1 bit</small></span>
    <span style="--span: 5">Adresse<small>5 bits</small></span>
    <span style="--span: 6">Commande<small>6 bits</small></span>
  </div>

  <div class="satellite-rc5__logic">
    <article>
      <strong>0 logique</strong>
      <span>transition <code>HIGH → LOW</code> au milieu du bit</span>
    </article>
    <article>
      <strong>1 logique</strong>
      <span>transition <code>LOW → HIGH</code> au milieu du bit</span>
    </article>
    <article>
      <strong>Timing</strong>
