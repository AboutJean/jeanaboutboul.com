<section class="not-prose satellite-sim surface-card" data-satellite-sim>
  <div class="satellite-sim__header">
    <div>
      <p class="kicker">Simulation interactive</p>
      <h3>Station de pointage virtuelle</h3>
    </div>
    <p>
      Une petite maquette web du firmware : télécommande RC5, couches
      <code>BROWSING</code>/<code>IN_MODE</code>, mode MANUEL, Go-To AUTO,
      sweep SCAN, LCD, UART et actionneurs.
    </p>
  </div>

  <div class="satellite-sim__status" aria-label="État courant de la simulation">
    <span>Mode <strong data-sim-output="mode">AUTO</strong></span>
    <span>Couche <strong data-sim-output="layer">BROWSING</strong></span>
    <span>Action <strong data-sim-output="action">IDLE</strong></span>
    <span>UART <strong data-sim-output="uart">ON</strong></span>
  </div>

  <div class="satellite-sim__grid">
    <div class="satellite-sim__column satellite-sim__column--hardware">
      <article class="satellite-sim__module">
        <h4>Servo élévation · PB5 / OC1A</h4>
        <div class="satellite-sim__servo" aria-hidden="true">
          <div class="satellite-sim__servo-body"></div>
          <div class="satellite-sim__servo-arm" data-sim-output="servo-arm"></div>
        </div>
        <p>EL <strong data-sim-output="el">0°</strong> · PWM <strong data-sim-output="pwm">500</strong></p>
      </article>

      <article class="satellite-sim__module">
        <h4>Stepper azimut · PORTD[0:3]</h4>
        <div class="satellite-sim__stepper" aria-hidden="true">
          <div class="satellite-sim__rotor" data-sim-output="stepper-rotor">
            <span></span>
          </div>
        </div>
        <p>AZ <strong data-sim-output="az">000°</strong> · <strong data-sim-output="partial-steps">0</strong> pas partiels</p>
      </article>

      <article class="satellite-sim__module satellite-sim__module--buzzer" data-sim-output="buzzer">
        <h4>IR + buzzer · PE7 / PE2</h4>
        <div class="satellite-sim__ir-row">
          <span class="satellite-sim__led" data-sim-output="rx-led"></span>
          <div class="satellite-sim__buzzer" aria-hidden="true"><span></span></div>
        </div>
        <p>Dernière commande <strong data-sim-output="last-command">INIT</strong></p>
      </article>
    </div>

    <div class="satellite-sim__column satellite-sim__column--core">
      <article class="satellite-sim__board">
        <div class="satellite-sim__trace satellite-sim__trace--a"></div>
        <div class="satellite-sim__trace satellite-sim__trace--b"></div>
        <div class="satellite-sim__chip">
          <span class="satellite-sim__chip-led" data-sim-output="mcu-led"></span>
          <strong>ATmega128L</strong>
          <small>4 MHz · FSM coopérative</small>
        </div>
      </article>

      <article class="satellite-sim__lcd-card">
        <h4>LCD HD44780 · XMEM</h4>
        <div class="satellite-sim__lcd" aria-label="LCD 16 par 2">
          <span data-sim-output="lcd-l1">MODE: AUTO</span>
          <span data-sim-output="lcd-l2">AZ:000 EL:000</span>
        </div>
      </article>

      <article class="satellite-sim__module">
        <h4>EEPROM / sélection</h4>
        <p>
          Slot <strong data-sim-output="slot">0</strong> ·
          <strong data-sim-output="satellite">ISS</strong>
        </p>
        <p>
          Slots valides <strong data-sim-output="valid-slots">10/32</strong> ·
          Hits SCAN <strong data-sim-output="scan-hits">0</strong>
        </p>
      </article>

      <article class="satellite-sim__terminal-card">
        <h4>UART terminal · 19 200 bps</h4>
        <pre data-sim-output="uart-term">System init... OK
FSM ready.</pre>
      </article>
    </div>

    <div class="satellite-sim__remote" aria-label="Télécommande RC5 simulée">
      <div class="satellite-sim__tx-led" data-sim-output="tx-led"></div>
      <div class="satellite-sim__remote-title">Vivanco UR Z2 · RC5</div>

      <div class="satellite-sim__remote-row">
        <button type="button" class="is-dark is-pill" data-sim-cmd="AV">AV</button>
        <button type="button" class="is-red is-pill" data-sim-cmd="POWER">POWER</button>
      </div>

      <div class="satellite-sim__remote-pad">
        <div class="satellite-sim__remote-stack">
          <button type="button" class="is-red" data-sim-hold="VOL+">+</button>
          <span>VOL</span>
          <button type="button" class="is-red" data-sim-hold="VOL-">-</button>
        </div>
        <div class="satellite-sim__remote-stack">
          <button type="button" class="is-dark is-small" data-sim-cmd="MUTE">M</button>
          <span>MUTE</span>
        </div>
        <div class="satellite-sim__remote-stack">
          <button type="button" class="is-red" data-sim-hold="CH+">▲</button>
          <span>CH</span>
          <button type="button" class="is-red" data-sim-hold="CH-">▼</button>
        </div>
      </div>

      <button type="button" class="is-blue is-wide" data-sim-cmd="GUIDE">GUIDE</button>

      <div class="satellite-sim__numpad">
        <button type="button" class="is-blue" data-sim-cmd="1">1</button>
        <button type="button" class="is-blue" data-sim-cmd="2">2</button>
        <button type="button" class="is-blue" data-sim-cmd="3">3</button>
        <button type="button" class="is-blue" data-sim-cmd="4">4</button>
        <button type="button" class="is-blue" data-sim-cmd="5">5</button>
        <button type="button" class="is-blue" data-sim-cmd="6">6</button>
        <button type="button" class="is-blue" data-sim-cmd="7">7</button>
        <button type="button" class="is-blue" data-sim-cmd="8">8</button>
        <button type="button" class="is-blue" data-sim-cmd="9">9</button>
        <button type="button" class="is-blue is-text" data-sim-cmd="DEL">DEL</button>
        <button type="button" class="is-blue" data-sim-cmd="0">0</button>
        <button type="button" class="is-blue is-text" data-sim-cmd="RESET">RST</button>
      </div>

      <p class="satellite-sim__hint">
        Astuce : maintiens <code>CH</code> ou <code>VOL</code> pour voir
        l'accélération RC5. <code>POWER</code> interrompt tout mouvement.
      </p>
    </div>
  </div>
</section>

<script is:inline>
  function initSatellitePointingSimulator(root) {
    if (root.dataset.ready === "true") return;
    root.dataset.ready = "true";

    const q = (selector) => root.querySelector(selector);
    const qa = (selector) => Array.from(root.querySelectorAll(selector));
    const out = (name) => q(`[data-sim-output="${name}"]`);

    const LAYER_BROWSING = 0;
    const LAYER_IN_MODE = 1;
    const MODE_AUTO = 0;
    const MODE_MANUEL = 1;
    const MODE_SCAN = 2;
    const MODE_NAMES = ["AUTO", "MANUEL", "SCAN"];

    const initialSatellites = [
      ["ISS", 257, 24],
      ["Hubble", 142, 56],
      ["Tiangong", 89, 72],
      ["Starlink", 310, 45],
      ["Envisat", 15, 81],
      ["NOAA-19", 198, 33],
      ["Iridium", 275, 65],
      ["Terra", 45, 12],
      ["Aqua", 120, 88],
      ["Suomi NPP", 82, 41],
    ];

    let audioCtx = null;
    let holdTimer = null;
    let overlayTimer = null;

    const state = {
      az: 0,
      el: 0,
      layer: LAYER_BROWSING,
      mode: MODE_AUTO,
      moving: false,
      phase: "idle",
      targetAz: 0,
      targetEl: 0,
      satCursor: 0,
      manualConfirmSave: false,
      autoConfirmDelete: false,
      uartEnabled: true,
      overlay: "",
      scanSteps: 0,
      scanHits: [],
      scanFilter: null,
      scanElAtStart: 0,
      lastCommand: "INIT",
      holdCount: 0,
      satellites: Array.from({ length: 32 }, (_, index) => {
        const sat = initialSatellites[index];
        return sat
          ? { name: sat[0], az: sat[1], el: sat[2], valid: true }
          : { name: `SAT ${String(index).padStart(2, "0")}`, az: 0, el: 0, valid: false };
      }),
    };

    function pad(value, length = 3) {
      return String(value).padStart(length, "0");
    }

    function lcdLine(value) {
      return String(value).padEnd(16, " ").slice(0, 16);
    }

    function wrapAz(value) {
      return ((value % 360) + 360) % 360;
    }

    function clamp(value, min, max) {
      return Math.min(max, Math.max(min, value));
    }

    function shortestDelta(current, target) {
      let delta = target - current;
      if (delta > 180) delta -= 360;
      if (delta < -180) delta += 360;
      return delta;
    }

    function validSlotIds() {
      const base = state.satellites
        .map((sat, id) => (sat.valid ? id : -1))
        .filter((id) => id >= 0);
      return state.scanFilter ? base.filter((id) => state.scanFilter.includes(id)) : base;
    }

    function currentSat() {
      return state.satellites[state.satCursor];
    }

    function firstValidSlot() {
      return validSlotIds()[0] ?? -1;
    }

    function stepCursor(direction) {
      const ids = validSlotIds();
      if (ids.length === 0) return;
      const currentIndex = Math.max(0, ids.indexOf(state.satCursor));
      state.satCursor = ids[(currentIndex + direction + ids.length) % ids.length];
    }

    function selectDirectSlot(cmd) {
      const slot = cmd === "0" ? 9 : Number(cmd) - 1;
      if (!Number.isInteger(slot)) return;
      const sat = state.satellites[slot];
      if (sat?.valid && (!state.scanFilter || state.scanFilter.includes(slot))) {
        state.satCursor = slot;
        logUART(`[AUTO] direct slot ${slot}: ${sat.name}`);
      } else {
        showOverlay("SLOT EMPTY");
      }
    }

    function setOverlay(message, ms = 650) {
      state.overlay = message;
      clearTimeout(overlayTimer);
      overlayTimer = setTimeout(() => {
        state.overlay = "";
        render();
      }, ms);
      render();
    }

    function logUART(message) {
      if (!state.uartEnabled) return;
      const term = out("uart-term");
      if (!term) return;
      const time = new Date().toLocaleTimeString("fr-CH", {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
      });
      term.textContent += `\n[${time}] ${message}`;
      term.scrollTop = term.scrollHeight;
    }

    function flash(element) {
      if (!element) return;
      element.classList.remove("is-flashing");
      void element.offsetWidth;
      element.classList.add("is-flashing");
      setTimeout(() => element.classList.remove("is-flashing"), 180);
    }

    function chirp(count = 1) {
      const buzzer = out("buzzer");
      buzzer?.classList.add("is-buzzing");
      setTimeout(() => buzzer?.classList.remove("is-buzzing"), 160 * count);

      const AudioContext = window.AudioContext || window.webkitAudioContext;
      if (!AudioContext) return;
      if (!audioCtx) audioCtx = new AudioContext();
      if (audioCtx.state === "suspended") audioCtx.resume();

      for (let i = 0; i < count; i += 1) {
        const start = audioCtx.currentTime + i * 0.13;
        const osc = audioCtx.createOscillator();
        const gain = audioCtx.createGain();
        osc.type = "square";
        osc.frequency.setValueAtTime(1500, start);
        osc.frequency.exponentialRampToValueAtTime(1000, start + 0.07);
        gain.gain.setValueAtTime(0.035, start);
        gain.gain.exponentialRampToValueAtTime(0.0001, start + 0.08);
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start(start);
        osc.stop(start + 0.08);
      }
    }

    function computeLcd() {
      let l1 = "";
      let l2 = `AZ:${pad(state.az)} EL:${pad(state.el)}`;

      if (state.layer === LAYER_BROWSING) {
        l1 = `MODE: ${MODE_NAMES[state.mode]}`;
      } else if (state.mode === MODE_AUTO) {
        const sat = currentSat();
        if (state.autoConfirmDelete) {
          l1 = "DEL? PUSH DEL";
        } else if (sat?.valid) {
          l1 = state.moving ? `GO TO ${sat.name}` : `Sat: ${sat.name}`;
          l2 = `AZ:${pad(sat.az)} EL:${pad(sat.el)}`;
        } else {
          l1 = "EMPTY";
        }
      } else if (state.mode === MODE_MANUEL) {
        l1 = state.manualConfirmSave ? "SAVE:PRESS GDE" : "MANUEL MOVING";
      } else if (state.mode === MODE_SCAN) {
        if (state.moving) {
          l1 = "SCAN: SWEEPING";
          l2 = `AZ:${pad(state.az)} HIT:${pad(state.scanHits.length, 2)}`;
        } else {
          l1 = "SCAN:PUSH GUIDE";
        }
      }

      if (state.overlay) l2 = state.overlay;
      return [lcdLine(l1), lcdLine(l2)];
    }

    function render() {
      const [l1, l2] = computeLcd();
      out("lcd-l1").textContent = l1;
      out("lcd-l2").textContent = l2;

      out("az").textContent = `${pad(state.az)}°`;
      out("el").textContent = `${state.el}°`;
      out("pwm").textContent = String(Math.round(500 + (state.el * 400) / 90));
      out("partial-steps").textContent = String(state.az * 3);
      out("mode").textContent = MODE_NAMES[state.mode];
      out("layer").textContent = state.layer === LAYER_BROWSING ? "BROWSING" : "IN_MODE";
      out("action").textContent = state.moving ? state.phase.toUpperCase() : "IDLE";
      out("uart").textContent = state.uartEnabled ? "ON" : "OFF";
      out("last-command").textContent = state.lastCommand;
      out("slot").textContent = String(state.satCursor);
      out("satellite").textContent = currentSat()?.valid ? currentSat().name : "EMPTY";
      out("valid-slots").textContent =
        `${state.satellites.filter((sat) => sat.valid).length}/32`;
      out("scan-hits").textContent = String(state.scanHits.length);

      out("stepper-rotor").style.transform = `rotate(${state.az}deg)`;
      out("servo-arm").style.transform = `rotate(${-90 + state.el}deg)`;
      out("mcu-led").classList.toggle("is-moving", state.moving);
      root.classList.toggle("is-moving", state.moving);
      root.classList.toggle("is-filtered", Boolean(state.scanFilter));

      qa("[data-sim-cmd], [data-sim-hold]").forEach((button) => {
        const disabled = state.moving && !["POWER", "MUTE"].includes(button.dataset.simCmd);
        button.toggleAttribute("aria-disabled", disabled);
      });
    }

    function resetSimulation() {
      state.az = 0;
      state.el = 0;
      state.layer = LAYER_BROWSING;
      state.mode = MODE_AUTO;
      state.moving = false;
      state.phase = "idle";
      state.satCursor = 0;
      state.manualConfirmSave = false;
      state.autoConfirmDelete = false;
      state.overlay = "";
      state.scanSteps = 0;
      state.scanHits = [];
      state.scanFilter = null;
      state.lastCommand = "RESET";
      clearTimeout(overlayTimer);
      out("uart-term").textContent = "System reset... OK\nFSM ready.";
      render();
      logUART("[SYS] reset");
    }

    function emergencyStop() {
      state.moving = false;
      state.phase = "idle";
      state.layer = LAYER_BROWSING;
      state.manualConfirmSave = false;
      state.autoConfirmDelete = false;
      state.scanFilter = null;
      state.overlay = "";
      clearTimeout(overlayTimer);
      chirp(2);
      logUART("[SYS] EMERGENCY STOP");
      render();
    }

    function handleManual(cmd) {
      if (state.manualConfirmSave) {
        state.manualConfirmSave = false;
        if (cmd === "GUIDE") {
          const freeSlot = state.satellites.findIndex((sat) => !sat.valid);
          if (freeSlot >= 0) {
            state.satellites[freeSlot] = {
              name: `SAT ${String(freeSlot).padStart(2, "0")}`,
              az: state.az,
              el: state.el,
              valid: true,
            };
            state.satCursor = freeSlot;
            setOverlay("SAVED");
            chirp(1);
            logUART(`[EEPROM] saved slot ${freeSlot} AZ:${state.az} EL:${state.el}`);
          } else {
            setOverlay("EEPROM FULL");
          }
        }
        render();
        return;
      }

      const fastness = state.holdCount >= 30 ? 10 : state.holdCount >= 10 ? 5 : 1;
      const elStep = fastness === 1 ? 2 : fastness;
      let moved = false;

      if (cmd === "CH+") {
        state.az = wrapAz(state.az + fastness);
        moved = true;
      } else if (cmd === "CH-") {
        state.az = wrapAz(state.az - fastness);
        moved = true;
      } else if (cmd === "VOL+") {
        state.el = clamp(state.el + elStep, 0, 90);
        moved = true;
      } else if (cmd === "VOL-") {
        state.el = clamp(state.el - elStep, 0, 90);
        moved = true;
      } else if (cmd === "GUIDE") {
        state.manualConfirmSave = true;
        logUART("[MANUEL] save armed");
      }

      if (moved) logUART(`[MANUEL] AZ:${state.az} EL:${state.el}`);
      render();
    }

    function handleAuto(cmd) {
      if (state.autoConfirmDelete) {
        state.autoConfirmDelete = false;
        if (cmd === "DEL" && currentSat()?.valid) {
          const deleted = currentSat().name;
          state.satellites[state.satCursor].valid = false;
          state.scanFilter = state.scanFilter?.filter((id) => id !== state.satCursor) ?? null;
          const next = firstValidSlot();
          if (next >= 0) state.satCursor = next;
          setOverlay("DELETED");
          chirp(1);
          logUART(`[EEPROM] deleted ${deleted}`);
        }
        render();
        return;
      }

      if (cmd === "CH+") {
        stepCursor(1);
      } else if (cmd === "CH-") {
        stepCursor(-1);
      } else if (/^[0-9]$/.test(cmd)) {
        selectDirectSlot(cmd);
      } else if (cmd === "DEL") {
        if (currentSat()?.valid) state.autoConfirmDelete = true;
      } else if (cmd === "GUIDE") {
        const sat = currentSat();
        if (!sat?.valid) {
          setOverlay("NO SAT");
          return;
        }
        state.targetAz = sat.az;
        state.targetEl = sat.el;
        state.moving = true;
        state.phase = "auto-az";
        logUART(`[AUTO] Go-To ${sat.name} AZ:${sat.az} EL:${sat.el}`);
      }

      render();
    }

    function handleScan(cmd) {
      if (cmd !== "GUIDE") return;
      state.scanSteps = 0;
      state.scanHits = [];
      state.scanFilter = null;
      state.scanElAtStart = state.el;
      state.moving = true;
      state.phase = "scan";
      logUART(`[SCAN] sweep start at EL:${state.el}`);
      render();
    }

    function dispatch(cmd, options = {}) {
      state.lastCommand = cmd;
      if (!options.repeat) state.holdCount = 0;
      flash(out("tx-led"));
      flash(out("rx-led"));

      if (cmd === "RESET") {
        resetSimulation();
        return;
      }

      if (cmd === "POWER") {
        emergencyStop();
        return;
      }

      if (cmd === "MUTE") {
        state.uartEnabled = !state.uartEnabled;
        setOverlay(state.uartEnabled ? "UART ON" : "UART OFF");
        if (state.uartEnabled) logUART("[SYS] UART enabled");
        render();
        return;
      }

      if (state.moving) {
        logUART(`[FSM] ignored ${cmd} while moving`);
        return;
      }

      if (cmd === "AV") {
        state.layer = state.layer === LAYER_BROWSING ? LAYER_IN_MODE : LAYER_BROWSING;
        state.manualConfirmSave = false;
        state.autoConfirmDelete = false;
        chirp(1);
        logUART(`[FSM] layer ${state.layer === LAYER_BROWSING ? "BROWSING" : "IN_MODE"}`);
        render();
        return;
      }

      if (state.layer === LAYER_BROWSING) {
        if (cmd === "CH+") state.mode = (state.mode + 1) % 3;
        if (cmd === "CH-") state.mode = (state.mode + 2) % 3;
        if (cmd === "CH+" || cmd === "CH-") {
          state.scanFilter = null;
          logUART(`[FSM] mode ${MODE_NAMES[state.mode]}`);
        }
        render();
        return;
      }

      if (state.mode === MODE_MANUEL) handleManual(cmd);
      if (state.mode === MODE_AUTO) handleAuto(cmd);
      if (state.mode === MODE_SCAN) handleScan(cmd);
    }

    function tickAuto() {
      if (state.phase === "auto-az") {
        const delta = shortestDelta(state.az, state.targetAz);
        if (delta === 0) {
          state.phase = "auto-el";
          return;
        }
        const step = Math.sign(delta) * Math.min(2, Math.abs(delta));
        state.az = wrapAz(state.az + step);
      } else if (state.phase === "auto-el") {
        const delta = state.targetEl - state.el;
        if (delta === 0) {
          state.moving = false;
          state.phase = "idle";
          setOverlay("ARRIVED", 900);
          chirp(1);
          logUART("[AUTO] arrived");
          return;
        }
        state.el += Math.sign(delta) * Math.min(2, Math.abs(delta));
      }
    }

    function tickScan() {
      for (let i = 0; i < 2 && state.scanSteps < 360; i += 1) {
        state.az = wrapAz(state.az + 1);
        state.scanSteps += 1;
        state.satellites.forEach((sat, id) => {
          if (!sat.valid || state.scanHits.includes(id)) return;
          if (sat.az === state.az && Math.abs(sat.el - state.scanElAtStart) <= 10) {
            state.scanHits.push(id);
            chirp(1);
            logUART(`[SCAN] hit ${sat.name}`);
          }
        });
      }

      if (state.scanSteps >= 360) {
        state.moving = false;
        state.phase = "idle";
        if (state.scanHits.length > 0) {
          state.scanFilter = [...state.scanHits];
          state.mode = MODE_AUTO;
          state.layer = LAYER_IN_MODE;
          state.satCursor = state.scanFilter[0];
          setOverlay(`${state.scanHits.length} SATS FOUND`, 1300);
          logUART(`[SCAN] ${state.scanHits.length} result(s), AUTO filtered`);
        } else {
          setOverlay("NO SATS FOUND", 1300);
          logUART("[SCAN] no result");
        }
        chirp(2);
      }
    }

    function mainLoop() {
      if (!state.moving) return;
      if (state.phase.startsWith("auto")) tickAuto();
      if (state.phase === "scan") tickScan();
      render();
    }

    qa("[data-sim-cmd]").forEach((button) => {
      button.addEventListener("click", () => dispatch(button.dataset.simCmd));
    });

    qa("[data-sim-hold]").forEach((button) => {
      const cmd = button.dataset.simHold;
      const stopHold = () => {
        clearInterval(holdTimer);
        holdTimer = null;
      };
      button.addEventListener("pointerdown", (event) => {
        event.preventDefault();
        stopHold();
        state.holdCount = 0;
        dispatch(cmd);
        holdTimer = setInterval(() => {
          state.holdCount += 1;
          dispatch(cmd, { repeat: true });
        }, 115);
      });
      button.addEventListener("pointerup", stopHold);
      button.addEventListener("pointerleave", stopHold);
      button.addEventListener("pointercancel", stopHold);
    });

    root.addEventListener("keydown", (event) => {
      const keyMap = {
        a: "CH+",
        d: "CH-",
        w: "VOL+",
        s: "VOL-",
        m: "AV",
        p: "POWER",
        x: "DEL",
        u: "MUTE",
        " ": "GUIDE",
      };
      const key = event.key.toLowerCase();
      const cmd = keyMap[key] || (/^[0-9]$/.test(key) ? key : null);
      if (!cmd) return;
      event.preventDefault();
      dispatch(cmd);
    });

    root.tabIndex = 0;
    setInterval(mainLoop, 34);
    render();
  }

  document
