---
interface Props {
  line1: string;
  line2: string;
  caption?: string;
}

const { line1, line2, caption } = Astro.props;
---

<figure class="not-prose satellite-lcd-mock" aria-label={caption ?? "LCD mockup"}>
  <div class="satellite-lcd-mock__screen">
    <span>{line1}</span>
    <span>{line2}</span>
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .satellite-lcd-mock {
    margin: 1.35rem 0;
  }

  .satellite-lcd-mock__screen {
    display: grid;
    gap: 0.25rem;
    width: min(100%, 26rem);
    border: 1px solid rgb(var(--color-line-strong));
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.11), transparent 24%),
      #a8b14e;
    box-shadow: inset 0 0 0 0.45rem rgba(0, 0, 0, 0.18);
    padding: 1.25rem 1.4rem;
  }

  .satellite-lcd-mock__screen span {
    display: block;
    min-height: 1.55rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
    font-size: clamp(1.2rem, 4vw, 1.65rem);
    font-weight: 800;
    letter-spacing: 0.05em;
    line-height: 1.15;
    color: #1d2418;
    text-transform: uppercase;
  }

  .satellite-lcd-mock figcaption {
    margin-top: 0.45rem;
    font-family: ui-sans-serif, system-ui, sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    color: rgb(var(--color-ink-faint));
  }
</style>
