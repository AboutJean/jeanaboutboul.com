<figure class="not-prose satellite-timing surface-card" aria-labelledby="satellite-timing-title">
  <figcaption>
    <p class="kicker">Signal PWM</p>
    <h3 id="satellite-timing-title">Un créneau de 20 ms pour commander l'élévation</h3>
    <p>
      Timer1 produit le signal en matériel. Le firmware ne fait que modifier
      <code>OCR1A</code>, donc la période reste stable et sans jitter logiciel.
    </p>
  </figcaption>

  <div class="satellite-timing__wave" aria-label="PWM timing diagram">
    <div class="satellite-timing__period">20 ms · 50 Hz</div>
    <svg viewBox="0 0 900 190" role="img" aria-labelledby="pwm-wave-title">
      <title id="pwm-wave-title">PWM servo : impulsions de 1.0 ms à 1.8 ms dans une période de 20 ms</title>
      <line x1="48" y1="128" x2="852" y2="128" class="baseline" />
      <polyline points="52,128 52,52 98,52 98,128 852,128" class="wave wave--zero" />
      <polyline points="52,156 52,92 134,92 134,156 852,156" class="wave wave--ninety" />
      <line x1="52" y1="36" x2="852" y2="36" class="period-line" />
      <line x1="52" y1="28" x2="52" y2="44" class="tick" />
      <line x1="852" y1="28" x2="852" y2="44" class="tick" />
      <text x="75" y="45" class="label">1.0 ms → 0°</text>
      <text x="146" y="87" class="label">1.8 ms → 90°</text>
      <text x="452" y="25" class="label label--center">période complète</text>
    </svg>
  </div>

  <div class="satellite-timing__formula">
    <strong>Conversion firmware</strong>
    <span><code>OCR1A = 500 + angle × 400 / 90</code></span>
  </div>
</figure>

