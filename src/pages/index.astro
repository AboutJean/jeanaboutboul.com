---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";
import {
  formatSemesterOrMonth,
  getProjectAccentTone,
  getTalkAccentTone,
  getTalkCategoryLabel,
  isEpflTalk,
  type AccentTone,
} from "../utils/content";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const allTalks = (await getCollection("talks")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const recentProjects = allProjects.slice(0, 2);
const recentTalks = allTalks.slice(0, 3);
const homeFacts: Array<{ label: string; tone: AccentTone; withLine: boolean; value: string[] }> = [
  {
    label: "Current focus",
    tone: "yellow",
    withLine: false,
    value: ["Robotics, control, embedded", "electronics, and technical", "communication."],
  },
  {
    label: "Interests",
    tone: "red",
    withLine: true,
    value: ["Music, philosophy."],
  },
  {
    label: "Studying",
    tone: "blue",
    withLine: true,
    value: ["BSc Microengineering, EPFL."],
  },
  {
    label: "Based in",
    tone: "yellow",
    withLine: true,
    value: ["Lausanne, Switzerland."],
  },
  {
    label: "Elsewhere",
    tone: "yellow",
    withLine: true,
    value: ["jeanaboutboul@gmail.com", "GitHub / LinkedIn"],
  },
];
---

<Layout title="Jean Aboutboul">
  <section class="grid gap-12 lg:grid-cols-[minmax(0,1.7fr)_15rem] lg:items-start">
    <div>
      <h1 class="max-w-4xl text-3xl font-bold leading-[0.95] tracking-tight text-ink sm:text-5xl lg:text-6xl">
        EN CONSTRUCTION...
      </h1>

      <p class="mt-6 max-w-3xl text-xl leading-relaxed text-ink-soft">
        I&rsquo;m a microengineering student at EPFL interested in robotics, astronomy,
        embedded systems, and low-level software. This site is a quiet archive of projects,
        talks, and technical notes.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a href="/projects" class="button-primary">
          View projects
        </a>
        <a href="/talks" class="button-secondary">
          Read notes
        </a>
      </div>

      <div class="home-kinetic-panel hidden lg:block" aria-hidden="true">
        <span class="home-kinetic-panel__line home-kinetic-panel__line--h1"></span>
        <span class="home-kinetic-panel__line home-kinetic-panel__line--h2"></span>
        <span class="home-kinetic-panel__line home-kinetic-panel__line--v1"></span>
        <span class="home-kinetic-panel__line home-kinetic-panel__line--v2"></span>
        <span class="home-kinetic-panel__tile home-kinetic-panel__tile--yellow"></span>
        <span class="home-kinetic-panel__tile home-kinetic-panel__tile--red"></span>
        <span class="home-kinetic-panel__tile home-kinetic-panel__tile--blue"></span>
        <span class="home-kinetic-panel__tile home-kinetic-panel__tile--paper"></span>
        <span class="home-kinetic-panel__tile home-kinetic-panel__tile--ink"></span>
      </div>
    </div>

    <dl class="home-hero__facts space-y-0 pt-1">
      {homeFacts.map((fact) => (
        <div class="home-hero__fact">
          <div class:list={["home-hero__fact-rule", !fact.withLine && "is-detached"]} aria-hidden="true">
            <span
              class:list={[
                "home-hero__fact-block",
                fact.tone === "yellow" && "home-hero__fact-block--yellow",
                fact.tone === "red" && "home-hero__fact-block--red",
                fact.tone === "blue" && "home-hero__fact-block--blue",
              ]}
            ></span>
            {fact.withLine && <span class="home-hero__fact-line"></span>}
          </div>

          <dt class="text-[0.68rem] uppercase tracking-[0.22em] text-ink-faint">{fact.label}</dt>

          {fact.label === "Elsewhere" ? (
            <dd class="space-y-1 text-sm leading-relaxed text-ink-soft">
              <p class="m-0">
                <a href="mailto:jeanaboutboul@gmail.com" class="hover:text-accent">
                  {fact.value[0]}
                </a>
              </p>
              <p class="m-0">
                <a href="https://github.com/AboutJean" class="hover:text-accent">GitHub</a>
                {" / "}
                <a href="https://www.linkedin.com/in/jean-aboutboul" class="hover:text-accent">
                  LinkedIn
                </a>
              </p>
            </dd>
          ) : (
            <dd class="space-y-1 text-sm leading-relaxed text-ink-soft">
              {fact.value.map((line) => (
                <p class="m-0">{line}</p>
              ))}
            </dd>
          )}
        </div>
      ))}
    </dl>
  </section>

  <section class="home-feature-grid mt-16 grid gap-8 pt-10 lg:grid-cols-[minmax(0,1.15fr)_minmax(0,0.9fr)]">
    <div class="home-feature-column">
      <div class="flex items-baseline justify-between gap-4">
        <p class="kicker">Recent projects</p>
        <a
          href="/projects"
          class="font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint hover:text-accent"
        >
          All projects
        </a>
      </div>
      <div class="home-feature-list home-feature-list--projects mt-4">
        {recentProjects.map((project) => (
          <a
            href={`/projects/${project.id}`}
            class:list={[
              "home-feature-card home-feature-card--project interactive-card card-padding-lg",
              `accent-${getProjectAccentTone(project)}`,
            ]}
          >
            <h2 class="text-3xl font-bold tracking-tight text-ink">{project.data.title}</h2>
            <p class="mt-4 max-w-2xl text-base leading-relaxed text-ink-soft">
              {project.data.summary}
            </p>
            <div class="tag-list mt-5">
              {project.data.tags.map((tag: string) => (
                <span class="tag-chip">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>

    <div class="home-feature-column">
      <div class="flex items-baseline justify-between gap-4">
        <p class="kicker">Recent notes</p>
        <a
          href="/talks"
          class="font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint hover:text-accent"
        >
          All notes
        </a>
      </div>

      <div class="home-feature-list home-feature-list--notes mt-4">
        {recentTalks.map((talk) => {
          const accentTone = getTalkAccentTone(talk);

          return (
            <a
              href={`/talks/${talk.id}`}
              class:list={[
                "home-feature-card home-feature-card--note interactive-card card-padding",
                `accent-${accentTone}`,
              ]}
            >
              <p
                class:list={[
                  "accent-copy font-sans text-[0.68rem] uppercase tracking-[0.18em]",
                  `accent-copy--${accentTone}`,
                ]}
              >
                {getTalkCategoryLabel(talk)}
              </p>
              <h3 class="mt-3 text-2xl font-bold tracking-tight text-ink">{talk.data.title}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-soft">
                {talk.data.summary}
              </p>
              <time class="mt-4 block font-sans text-[0.68rem] uppercase tracking-[0.18em] text-ink-faint">
                {formatSemesterOrMonth(talk.data.date, isEpflTalk(talk))}
              </time>
            </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>
